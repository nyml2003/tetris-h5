{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": [
      "node"
    ],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo/tsconfig.node.tsbuildinfo"
  },
  "include": [
    "scripts/**/*.ts",
    "vite.config.ts",
    "playwright.config.ts",
    "eslint.config.ts"
  ]
}
